{
  "uid": "cc-tools-activity",
  "title": "Claude Code - Tools & Activity",
  "schemaVersion": 39,
  "version": 1,
  "time": {"from": "now-24h", "to": "now"},
  "timezone": "browser",
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "コード編集ツール 決定 (accept/reject)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (decision)(max_over_time(claude_code_code_edit_tool_decision_total[$__interval]))", "refId": "A", "legendFormat": "{{decision}}"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 2, "type": "piechart", "title": "ツール別 実行回数 (Loki, 期間)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "sum by (tool_name) (count_over_time({service_name=\"claude-code\"} | event_name=\"tool_result\" [$__range]))", "refId": "A", "legendFormat": "{{tool_name}}"}]
    },
    {
      "id": 3, "type": "timeseries", "title": "API エラー / 拒否 (Loki)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"expr": "sum(count_over_time({service_name=\"claude-code\"} | event_name=\"api_error\" [5m]))", "refId": "A", "legendFormat": "api_error"},
        {"expr": "sum(count_over_time({service_name=\"claude-code\"} | event_name=\"api_refusal\" [5m]))", "refId": "B", "legendFormat": "api_refusal"}
      ]
    },
    {
      "id": 5, "type": "piechart", "title": "スキル別 呼び出し回数",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "sum by (skill_name) (count_over_time({service_name=\"claude-code\"} | event_name=\"tool_result\" | tool_name=\"Skill\" | line_format \"{{.tool_parameters}}\" | json | skill_name != \"\" [$__range]))", "refId": "A", "legendFormat": "{{skill_name}}"}]
    },
    {
      "id": 6, "type": "piechart", "title": "MCPツール別 呼び出し回数",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "sum by (mcp_server_name, mcp_tool_name) (count_over_time({service_name=\"claude-code\"} | event_name=\"tool_result\" | tool_name=\"mcp_tool\" | line_format \"{{.tool_parameters}}\" | json | mcp_server_name != \"\" [$__range]))", "refId": "A", "legendFormat": "{{mcp_server_name}}/{{mcp_tool_name}}"}]
    },
    {
      "id": 7, "type": "logs", "title": "スキル / MCP 呼び出しログ (直近)",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "{service_name=\"claude-code\"} | event_name=\"tool_result\" | tool_name=~\"Skill|mcp_tool\" | line_format \"{{.tool_parameters}}\" | json | line_format \"[{{.tool_name}}] skill={{.skill_name}} mcp={{.mcp_server_name}}/{{.mcp_tool_name}}\"", "refId": "A"}],
      "options": {"showTime": true, "wrapLogMessage": true, "dedupStrategy": "none"}
    },
    {
      "id": 4, "type": "logs", "title": "イベントログ (最新・メタデータ)",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 32},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "{service_name=\"claude-code\"}", "refId": "A"}],
      "options": {"showTime": true, "wrapLogMessage": true, "dedupStrategy": "none"}
    }
  ]
}
