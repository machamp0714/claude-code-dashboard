# ---- ports (host side) ----
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
LOKI_PORT=3100
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318
OTELCOL_METRICS_PORT=8889
OTELCOL_HEALTH_PORT=13133

# ---- retention ----
PROMETHEUS_RETENTION=90d
# Loki 保持期間は loki/config.yaml の retention_period を直接編集（既定 720h=30日）

# ---- grafana ----
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ---- image tags (pinned) ----
OTELCOL_IMAGE=otel/opentelemetry-collector-contrib:0.116.1
PROMETHEUS_IMAGE=prom/prometheus:v3.1.0
LOKI_IMAGE=grafana/loki:3.3.2
GRAFANA_IMAGE=grafana/grafana:11.4.0
